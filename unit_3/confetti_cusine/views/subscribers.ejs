<section>
  <div class="container">
    <h2>Subscribers</h2>
    <p class="text-muted mb-4">Everyone who has signed up for updates.</p>

    <div class="row">
      <% subscribers.forEach(s => { %>
      <div class="col-md-4 mb-4">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><%= s.name %></h5>
            <p class="card-text text-muted"><%= s.email %></p>
          </div>
        </div>
      </div>
      <% }) %>
    </div>

  </div>
</section>
