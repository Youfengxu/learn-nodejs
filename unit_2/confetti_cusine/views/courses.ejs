<section>
  <div class="container">
    <h2 class="mb-4">Our Courses</h2>
    <div class="row align-items-start">

      <!-- Image -->
      <div class="col-md-5 mb-4">
        <img src="/images/product.jpg" alt="Delicious food" class="img-fluid rounded">
      </div>

      <!-- Course list -->
      <div class="col-md-7">
        <% offeredCourses.forEach(course => { %>
        <div class="card mb-3">
          <div class="card-body d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0"><%= course.title %></h5>
            <span class="badge badge-primary">$<%= course.cost %></span>
          </div>
        </div>
        <% }); %>
      </div>

    </div>
  </div>
</section>
